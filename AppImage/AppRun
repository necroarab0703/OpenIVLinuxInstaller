#!/bin/bash
################################################################################
# OpenIV AppImage AppRun
# This script runs when the AppImage is launched.
# It checks for the existing installation or runs the installer.
################################################################################

HERE="$(dirname "$(readlink -f "$0")")"
OPENIV_DIR="$HOME/.OpenIV"
OPENIV_PREFIX="$OPENIV_DIR/prefix"

# Colors
if [ -t 1 ]; then
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
    BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; BOLD=''; NC=''
fi

check_openiv_installed() {
    local paths=(
        "$OPENIV_PREFIX/drive_c/Program Files/OpenIV/OpenIV.exe"
        "$OPENIV_PREFIX/drive_c/Program Files (x86)/OpenIV/OpenIV.exe"
        "$OPENIV_PREFIX/drive_c/Program Files/OpenIV/OpenIV Launcher.exe"
        "$OPENIV_PREFIX/drive_c/Program Files (x86)/OpenIV/OpenIV Launcher.exe"
    )
    for p in "${paths[@]}"; do
        if [ -f "$p" ]; then
            echo "$p"
            return 0
        fi
    done
    # Broader search
    local found=$(find "$OPENIV_PREFIX/drive_c" -name "OpenIV*.exe" -type f 2>/dev/null | head -1)
    if [ -n "$found" ]; then
        echo "$found"
        return 0
    fi
    return 1
}

launch_openiv() {
    local exe_path=$1
    export WINEPREFIX="$OPENIV_PREFIX"
    export WINEDEBUG="-all"

    echo -e "${GREEN}Launching OpenIV...${NC}"
    cd "$OPENIV_PREFIX/drive_c/Program Files/OpenIV" 2>/dev/null || \
    cd "$OPENIV_PREFIX/drive_c/Program Files (x86)/OpenIV" 2>/dev/null || true

    wine "$exe_path"
}

clear
echo ""
echo -e "${CYAN}  ╔══════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}  ║${NC}        ${BOLD}OpenIV - Linux Edition (AppImage)${NC}                ${CYAN}║${NC}"
echo -e "${CYAN}  ╚══════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Check if OpenIV is already installed
OPENIV_EXE=$(check_openiv_installed)

if [ -n "$OPENIV_EXE" ]; then
    echo -e "${GREEN}OpenIV is already installed.${NC}"
    echo ""
    echo -e "  ${GREEN}1.${NC} Launch OpenIV"
    echo -e "  ${GREEN}2.${NC} Re-run installer"
    echo -e "  ${GREEN}3.${NC} Exit"
    echo ""
    echo -n -e "${BOLD}Select an option: ${NC}"
    read -r choice

    case $choice in
        1)
            launch_openiv "$OPENIV_EXE"
            ;;
        2)
            echo -e "${YELLOW}Starting installer...${NC}"
            bash "$HERE/OpenIVLinuxInstaller.sh"
            ;;
        3)
            exit 0
            ;;
    esac
else
    echo -e "${YELLOW}OpenIV is not installed yet.${NC}"
    echo -e "${GREEN}Starting the automatic installer...${NC}"
    echo ""
    bash "$HERE/OpenIVLinuxInstaller.sh"
fi
