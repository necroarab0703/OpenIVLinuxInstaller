#!/bin/bash
################################################################################
# OpenIV AppImage AppRun
#
# On first run:  deploys portable Wine + installs OpenIV automatically.
# Subsequent:    launches OpenIV directly.
#
# All state lives under $XDG_DATA_HOME/openiv-linux/ ($HOME/.local/share/ by
# default).  No system packages, no root, no prompts.
################################################################################
set -euo pipefail

HERE="$(dirname "$(readlink -f "$0")")"
export APPDIR="$HERE"

# Forward everything to the installer script; it is idempotent and will
# skip already-completed steps.  The installer itself handles the "first
# run vs. subsequent run" logic internally.
exec bash "$HERE/OpenIVLinuxInstaller.sh" "$@"
