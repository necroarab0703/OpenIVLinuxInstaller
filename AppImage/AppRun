#!/bin/bash
################################################################################
# OpenIV AppImage AppRun
#
# The AppRun exports $APPDIR (set automatically by the AppImage runtime)
# and then delegates to the bundled installer script.
#
# Because the installer is now fully idempotent and prefix extraction takes
# only a few seconds, this is a simple passthrough.
################################################################################
set -euo pipefail

HERE="$(dirname "$(readlink -f "$0")")"
export APPDIR="$HERE"

exec bash "$HERE/OpenIVLinuxInstaller.sh" "$@"
